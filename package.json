{
  "author": "Vladimir Barbarosh <vladimir.barbarosh@gmail.com> (https://github.com/vbarbarosh)",
  "name": "@vbarbarosh/smcss",
  "version": "2.0.0",
  "description": "A way to organize and write CSS",
  "license": "MIT",
  "main": "index.sass",
  "unpkg": "dist/sm.css",
  "jsdelivr": "dist/sm.css",
  "homepage": "https://smcss.vbarbarosh.com",
  "files": [
    "src/smcss",
    "!src/smcss/experimental",
    "dist/*.css"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vbarbarosh/smcss.git"
  },
  "keywords": [
    "css",
    "sass"
  ],
  "engines": {
    "node": ">=18"
  },
  "peerDependencies": {
    "sass": ">=1.33.0"
  },
  "peerDependenciesMeta": {
    "sass": {
      "optional": true
    }
  },
  "browserslist": [
    "IE >= 10",
    "Edge >= 12",
    "Chrome >= 40",
    "Firefox >= 40",
    "Safari >= 7",
    "iOS >= 7"
  ],
  "scripts": {
    "build": "rm -rf build && sass demos/demo.sass | postcss -o demos/demo.css && rm -rf dist && mkdir dist && sass demos/sm.sass | postcss -o dist/sm.css && csso --no-restructure dist/sm.css -o dist/sm.min.css && cp reset/reset.css dist/reset.css",
    "test": "mocha",
    "version": "bin/sync-version"
  },
  "devDependencies": {
    "@vbarbarosh/node-helpers": "^3.75.0",
    "autoprefixer": "^10.5.2",
    "csso": "^5.0.5",
    "csso-cli": "^4.0.2",
    "mocha": "^11.7.6",
    "postcss": "^8.5.19",
    "postcss-cli": "^11.0.1",
    "puppeteer": "^25.3.0",
    "sass": "^1.101.0",
    "sass-migrator": "^2.6.1"
  },
  "overrides": {
    "diff": "^9.0.0",
    "serialize-javascript": "^7.0.7"
  }
}
