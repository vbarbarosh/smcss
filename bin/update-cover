#!/usr/bin/env node

// Render img/cover.html (1280x640) to img/cover.png. The VERSION cell in
// the title block is kept current by bin/sync-version; run this after a
// version bump. bin/update-docs copies the result to docs/cover.png.

const cli = require('@vbarbarosh/node-helpers/src/cli');
const fs_path_join = require('@vbarbarosh/node-helpers/src/fs_path_join');
const puppeteer = require('puppeteer');

cli(main);

async function launch()
{
    try {
        return await puppeteer.launch();
    }
    catch (error) {
        // environments without unprivileged user namespaces (containers,
        // Ubuntu 23.10+ AppArmor); fine for rendering a local file
        return await puppeteer.launch({args: ['--no-sandbox']});
    }
}

async function main()
{
    const root = fs_path_join(__dirname, '..');
    const browser = await launch();
    try {
        const page = await browser.newPage();
        await page.setViewport({width: 1280, height: 640, deviceScaleFactor: 2});
        await page.goto('file://' + fs_path_join(root, 'img', 'cover.html'), {waitUntil: 'networkidle0'});
        await page.evaluate(() => document.fonts.ready);
        await page.screenshot({path: fs_path_join(root, 'img', 'cover.png')});
        console.log('img/cover.png: rendered from img/cover.html');
    }
    finally {
        await browser.close();
    }
}
